generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["fantasia"]
}

// ==================== ADMIN ====================
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      ActivityLog[]
  @@schema("fantasia")
}

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  admin     AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
  @@schema("fantasia")
}

// ==================== CUSTOMER ====================
model Customer {
  id          String   @id @default(cuid())
  phone       String   @unique
  email       String?  @unique
  password    String
  name        String
  birthdate   DateTime?
  gender      String?
  avatar      String?
  vipTier     String   @default("none")
  loyaltyPts  Int      @default(0)
  totalSpent  Float    @default(0)
  notes       String?
  blocked     Boolean  @default(false)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Atelier Address Book — preferences
  height           Int?
  weight           Int?
  preferredSize    String?
  preferredColors  String?
  preferredStyles  String?
  preferredFabrics String?
  shoulderWidth    Int?
  chestSize        Int?
  waistSize        Int?
  inseam           Int?
  onboarded        Boolean   @default(false)

  addresses   Address[]
  orders      Order[]
  wishlist    WishlistItem[]
  cultMember  CultMember?
  bespokes    BespokeRequest[]
  madeForOne  MadeForOne[]
  @@schema("fantasia")
}

model Address {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recipient   String
  country     String   @default("Iraq")
  governorate String
  city        String
  area        String?
  street      String?
  details     String?
  phone       String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
  @@schema("fantasia")
}

// ==================== CATALOG ====================
model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  nameAr      String
  nameEn      String
  descAr      String?
  descEn      String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  order       Int        @default(0)
  active      Boolean    @default(true)
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  @@schema("fantasia")
}

model Collection {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameAr      String
  nameEn      String
  descAr      String?
  descEn      String?
  image       String?
  banner      String?
  releaseAt   DateTime?
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@schema("fantasia")
}

model Product {
  id           String   @id @default(cuid())
  slug         String   @unique
  sku          String?  @unique
  nameAr       String
  nameEn       String
  taglineAr    String?
  taglineEn    String?
  descAr       String?
  descEn       String?
  priceIQD     Int
  priceUSD     Float
  compareIQD   Int?
  compareUSD   Float?
  cost         Float?
  stock        Int      @default(0)
  trackStock   Boolean  @default(true)
  weight       Float?
  active       Boolean  @default(true)
  featured     Boolean  @default(false)
  isNew        Boolean  @default(false)
  isLimited    Boolean  @default(false)
  metaTitle    String?
  metaDesc     String?
  order        Int      @default(0)

  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])

  images       ProductImage[]
  variants     ProductVariant[]
  orderItems   OrderItem[]
  wishlist     WishlistItem[]
  notes        AtelierNote[]
  madeForOne   MadeForOne?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@schema("fantasia")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int     @default(0)
  @@schema("fantasia")
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size       String?
  color      String?
  colorHex   String?
  sku        String?
  stock      Int     @default(0)
  priceIQD   Int?
  priceUSD   Float?
  orderItems OrderItem[]
  @@schema("fantasia")
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  @@unique([customerId, productId])
  @@schema("fantasia")
}

// ==================== ORDERS ====================
model Order {
  id            String   @id @default(cuid())
  number        String   @unique
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  guestName     String?
  guestPhone    String?
  guestEmail    String?
  addressId     String?
  address       Address? @relation(fields: [addressId], references: [id])
  shipAddress   String?
  currency      String   @default("IQD")
  subtotal      Float
  shipping      Float    @default(0)
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float
  status        String   @default("pending")
  paymentStatus String   @default("unpaid")
  paymentMethod String   @default("cod")
  notes         String?
  trackingCode  String?
  items         OrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@schema("fantasia")
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  nameAr      String
  nameEn      String
  image       String?
  size        String?
  color       String?
  qty         Int
  priceIQD    Int
  priceUSD    Float
  totalIQD    Int
  totalUSD    Float
  @@schema("fantasia")
}

// ==================== CULT ====================
model CultTier {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameAr    String
  nameEn    String
  descAr    String?
  descEn    String?
  priceIQD  Int
  priceUSD  Float
  perks     String
  color     String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  members   CultMember[]
  createdAt DateTime @default(now())
  @@schema("fantasia")
}

model CultMember {
  id         String   @id @default(cuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tierId     String
  tier       CultTier @relation(fields: [tierId], references: [id])
  startedAt  DateTime @default(now())
  expiresAt  DateTime?
  active     Boolean  @default(true)
  @@schema("fantasia")
}

// ==================== CONTENT ====================
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  valueAr   String
  valueEn   String
  type      String   @default("text")
  group     String?
  updatedAt DateTime @updatedAt
  @@schema("fantasia")
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  type      String
  alt       String?
  size      Int?
  width     Int?
  height    Int?
  folder    String?
  createdAt DateTime @default(now())
  @@schema("fantasia")
}

model ArchiveItem {
  id        String   @id @default(cuid())
  titleAr   String
  titleEn   String
  descAr    String?
  descEn    String?
  type      String
  cover     String
  media     String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  @@schema("fantasia")
}

// ==================== MARKETING ====================
model NewsletterSub {
  id        String   @id @default(cuid())
  contact   String   @unique
  type      String   @default("phone")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  @@schema("fantasia")
}

model Discount {
  id           String   @id @default(cuid())
  code         String   @unique
  type         String
  value        Float
  minSubtotal  Float?
  maxUses      Int?
  usedCount    Int      @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  @@schema("fantasia")
}

// ==================== SHIPPING ====================
model ShippingZone {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String
  governorates String
  priceIQD    Int
  priceUSD    Float
  etaDays     String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  @@schema("fantasia")
}

// ==================== BESPOKE ====================
model BespokeRequest {
  id              String   @id @default(cuid())
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name            String
  phone           String
  email           String?
  occasion        String
  preferredDate   String?
  fitPreference   String?
  fabricPreference String?
  budget          String?
  contactMethod   String   @default("whatsapp")
  city            String?
  notes           String?
  status          String   @default("new")
  internalNotes   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@schema("fantasia")
}

// ==================== ATELIER NOTES ====================
model AtelierNote {
  id        String   @id @default(cuid())
  number    Int      @unique
  textAr    String
  textEn    String
  signature String?  @default("ع. / A.")
  noteDate  DateTime @default(now())
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  image     String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("fantasia")
}

// ==================== MADE FOR ONE ====================
model MadeForOne {
  id           String   @id @default(cuid())
  productId    String   @unique
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  edition      String?
  personalNote String?
  claimedAt    DateTime?
  status       String   @default("available")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@schema("fantasia")
}

// ==================== SETTINGS ====================
model Setting {
  key       String   @id
  value     String
  group     String?
  updatedAt DateTime @updatedAt
  @@schema("fantasia")
}
