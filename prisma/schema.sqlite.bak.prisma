generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== ADMIN ====================
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin") // admin | superadmin | editor
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      ActivityLog[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  admin     AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
}

// ==================== CUSTOMER ====================
model Customer {
  id          String   @id @default(cuid())
  phone       String   @unique
  email       String?  @unique
  password    String
  name        String
  birthdate   DateTime?
  gender      String?
  avatar      String?
  vipTier     String   @default("none") // none | bronze | silver | gold | black
  loyaltyPts  Int      @default(0)
  totalSpent  Float    @default(0)
  notes       String?
  blocked     Boolean  @default(false)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addresses   Address[]
  orders      Order[]
  wishlist    WishlistItem[]
  cultMember  CultMember?
}

model Address {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recipient   String
  country     String   @default("Iraq")
  governorate String
  city        String
  area        String?
  street      String?
  details     String?
  phone       String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

// ==================== CATALOG ====================
model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  nameAr      String
  nameEn      String
  descAr      String?
  descEn      String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  order       Int        @default(0)
  active      Boolean    @default(true)
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Collection {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameAr      String
  nameEn      String
  descAr      String?
  descEn      String?
  image       String?
  banner      String?
  releaseAt   DateTime?
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id           String   @id @default(cuid())
  slug         String   @unique
  sku          String?  @unique
  nameAr       String
  nameEn       String
  taglineAr    String?
  taglineEn    String?
  descAr       String?
  descEn       String?
  priceIQD     Int
  priceUSD     Float
  compareIQD   Int?
  compareUSD   Float?
  cost         Float?
  stock        Int      @default(0)
  trackStock   Boolean  @default(true)
  weight       Float?
  active       Boolean  @default(true)
  featured     Boolean  @default(false)
  isNew        Boolean  @default(false)
  isLimited    Boolean  @default(false)
  metaTitle    String?
  metaDesc     String?
  order        Int      @default(0)

  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])

  images       ProductImage[]
  variants     ProductVariant[]
  orderItems   OrderItem[]
  wishlist     WishlistItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int     @default(0)
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size       String?
  color      String?
  colorHex   String?
  sku        String?
  stock      Int     @default(0)
  priceIQD   Int?
  priceUSD   Float?
  orderItems OrderItem[]
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  @@unique([customerId, productId])
}

// ==================== ORDERS ====================
model Order {
  id            String   @id @default(cuid())
  number        String   @unique
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  guestName     String?
  guestPhone    String?
  guestEmail    String?
  addressId     String?
  address       Address? @relation(fields: [addressId], references: [id])
  shipAddress   String?  // snapshot JSON
  currency      String   @default("IQD") // IQD | USD
  subtotal      Float
  shipping      Float    @default(0)
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float
  status        String   @default("pending") // pending|paid|processing|shipped|delivered|cancelled|refunded
  paymentStatus String   @default("unpaid")  // unpaid|paid|refunded
  paymentMethod String   @default("cod")     // cod|card|transfer
  notes         String?
  trackingCode  String?
  items         OrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  nameAr      String
  nameEn      String
  image       String?
  size        String?
  color       String?
  qty         Int
  priceIQD    Int
  priceUSD    Float
  totalIQD    Int
  totalUSD    Float
}

// ==================== CULT (membership) ====================
model CultTier {
  id        String   @id @default(cuid())
  slug      String   @unique // bronze | silver | gold | black
  nameAr    String
  nameEn    String
  descAr    String?
  descEn    String?
  priceIQD  Int
  priceUSD  Float
  perks     String   // JSON array
  color     String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  members   CultMember[]
  createdAt DateTime @default(now())
}

model CultMember {
  id         String   @id @default(cuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tierId     String
  tier       CultTier @relation(fields: [tierId], references: [id])
  startedAt  DateTime @default(now())
  expiresAt  DateTime?
  active     Boolean  @default(true)
}

// ==================== CONTENT / CMS ====================
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique // hero.title, identity.quote, ...
  valueAr   String
  valueEn   String
  type      String   @default("text") // text | rich | image | video
  group     String?  // gate | identity | archive | cult | signal | settings
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  type      String   // image | video | audio
  alt       String?
  size      Int?
  width     Int?
  height    Int?
  folder    String?
  createdAt DateTime @default(now())
}

model ArchiveItem {
  id        String   @id @default(cuid())
  titleAr   String
  titleEn   String
  descAr    String?
  descEn    String?
  type      String   // reel | edit | campaign | photo
  cover     String
  media     String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==================== MARKETING ====================
model NewsletterSub {
  id        String   @id @default(cuid())
  contact   String   @unique // phone or email
  type      String   @default("phone") // phone | email
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Discount {
  id           String   @id @default(cuid())
  code         String   @unique
  type         String   // percent | fixed
  value        Float
  minSubtotal  Float?
  maxUses      Int?
  usedCount    Int      @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ==================== SHIPPING ====================
model ShippingZone {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String
  governorates String  // JSON array of governorate names
  priceIQD    Int
  priceUSD    Float
  etaDays     String?  // "2-4"
  active      Boolean  @default(true)
  order       Int      @default(0)
}

// ==================== SETTINGS ====================
model Setting {
  key       String   @id
  value     String
  group     String?
  updatedAt DateTime @updatedAt
}
