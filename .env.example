# --- Database (Supabase pooler) ---
# Hostname MUST be aws-1- (NOT aws-0-). Use connection_limit=5 + pool_timeout=20.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=fantasia&connection_limit=5&pool_timeout=20"
# Direct (no pgbouncer) for Prisma migrations
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?schema=fantasia"

# --- Auth ---
# Random 32+ char string. App throws on startup if missing outside development.
JWT_SECRET="<random-32+-chars>"

# Seeded by prisma/seed.ts. Change in production after first login.
ADMIN_EMAIL="admin@aqeelfantasia.com"
ADMIN_PASSWORD="<change-me>"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Supabase (storage) ---
NEXT_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
# service_role JWT — server only, never exposed to the client.
SUPABASE_SERVICE_KEY="<service-role-jwt>"
